<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="omni_wheel" params="prefix">
    <link name="${prefix}_link">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}" /></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <material name="grey" />
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_length}" /></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_length}" />
    </link>
    <gazebo reference="${prefix}_link">
      <mu1 value="0.01"/><mu2 value="0.01"/>
    </gazebo>
  </xacro:macro>

  <xacro:omni_wheel prefix="wheel_A" />
  <xacro:omni_wheel prefix="wheel_B" />
  <xacro:omni_wheel prefix="wheel_C" />

  <gazebo reference="wheel_A_link">
    <mu1 value="1.0"/> <mu2 value="1.0"/> </gazebo>

  <gazebo reference="wheel_B_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <gazebo reference="wheel_C_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <joint name="wheel_A_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_A_link"/>
    <origin rpy="0 0 -1.57" xyz="0.3 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/> </joint>

  <joint name="wheel_B_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_B_link"/>
    <origin rpy="0 0 0.523" xyz="-0.14998395164135145 0.2598168859986678 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/> </joint>

  <joint name="wheel_C_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_C_link"/>
    <origin rpy="0 0 2.617" xyz="-0.1500320950002983 -0.2597890884348714 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="100.0"/> </joint>

</robot>